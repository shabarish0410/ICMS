# Spark Innovation Center Backend
APP_NAME="Spark Innovation Center API"
APP_VERSION=1.0.0
DEBUG=True

# Database
# For local dev without Docker (uses SQLite):
DATABASE_URL=sqlite:///./spark.db
# For Docker / PostgreSQL:
# DATABASE_URL=postgresql://spark_user:spark_password@localhost:5432/spark_db

# JWT Security (CHANGE IN PRODUCTION!)
SECRET_KEY=your-super-secret-key-change-in-production-at-least-32-chars-long
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
CORS_ORIGINS=http://localhost:3000

# File Upload
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760

# Email (optional - fill for email notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# Google OAuth (optional - fill for Google login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
